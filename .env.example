# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/day-win

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth (either pair works)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Site URL for auth (NextAuth v5 uses AUTH_URL; NEXTAUTH_URL still supported by some hosts)
AUTH_URL=http://localhost:3000
# NEXTAUTH_URL=http://localhost:3000

# Optional production
# AUTH_URL=https://your-domain.com
